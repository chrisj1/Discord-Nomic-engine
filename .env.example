# ── Required ───────────────────────────────────────────────────────────────────

# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your-bot-token-here

# ── Recommended ────────────────────────────────────────────────────────────────

# Sync slash commands to a specific guild for instant updates during development.
# For production, remove this and commands will sync globally (up to 1 hour lag).
DISCORD_GUILD_ID=your-guild-id-here

# ── Optional ───────────────────────────────────────────────────────────────────

# Override if nomic-rules isn't cloned next to nomic-engine.
# Default: ../nomic-rules  (relative to docker-compose.yml location)
# RULES_REPO_PATH=/absolute/path/to/nomic-rules

# Override the path inside the container where rules.py lives.
# Default: /app/rules/rules.py
# RULES_PATH=/app/rules/rules.py
